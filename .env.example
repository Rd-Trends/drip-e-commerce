# Database Configuration
# DATABASE_URI="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URI=postgres://postgres:postgres@127.0.0.1:5432/drip-e-commerce

# Payload CMS Configuration
PAYLOAD_SECRET=YOUR_SECRET_HERE
SITE_NAME="Payload Commerce"
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Paystack API keys
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# Local development flag
IS_LOCAL=true

# S3-Compatible Storage (Cloudflare R2, AWS S3, etc.)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key

# Resend API Key for email notifications
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_NAME="Your Store Name"
EMAIL_FROM_ADDRESS="noreply@yourdomain.com"

